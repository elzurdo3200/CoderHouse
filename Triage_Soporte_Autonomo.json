      "parameters": {
        "jsCode": "const email = $input.first().json;\n\n// Extraer FROM\nlet from = 'unknown';\nif (email.from && email.from.value && email.from.value[0]) {\n  from = email.from.value[0].address || 'unknown';\n}\nif (email.headers && email.headers.from) {\n  from = email.headers.from.replace('From: ', '').trim();\n}\n\n// Extraer SUBJECT\nlet subject = email.subject || 'No Subject';\nif (email.headers && email.headers.subject) {\n  subject = email.headers.subject.replace('Subject: ', '').trim();\n}\n\n// Extraer BODY - PRIORIDAD: text > textAsHtml > html > snippet\nlet body = '';\nif (email.text) {\n  body = email.text.trim();\n} else if (email.textAsHtml) {\n  body = email.textAsHtml.trim();\n} else if (email.html) {\n  body = email.html.trim();\n} else if (email.snippet) {\n  body = email.snippet.trim();\n} else {\n  body = 'Sin contenido';\n}\n\nreturn [{json: {email: from, subject: subject, body: body}}];"
      },
