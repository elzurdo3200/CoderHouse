    {
      "parameters": {
        "jsCode": "const ticketData = $node[\"Create Ticket\"].json.fields || {};\nconst ticketId = $node[\"Create Ticket\"].json.id;\nconst email = ticketData.Email_Origen || 'unknown';\nconst subject = ticketData.Asunto || 'No Subject';\nconst body = ticketData.Cuerpo || 'Sin contenido';\n\nconst payload = {\n  model: 'claude-opus-4-6',\n  max_tokens: 1024,\n  messages: [\n    {\n      role: 'user',\n      content: 'Email: ' + email + '\\nAsunto: ' + subject + '\\nCuerpo: ' + body + '\\nResponde SOLO JSON con: categoria, prioridad, solucion_sugerida, tiempo_estimado_horas, confidence'\n    }\n  ]\n};\nreturn [{json: {payload: JSON.stringify(payload), ticketId: ticketId}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        40000,
        3936
      ],
