      "name": "Call Claude API",
      "credentials": {
        "anthropicApi": {
          "id": "JUxCFbctSfIff7L0",
          "name": "Anthropic account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nif (!response.content || !response.content[0] || !response.content[0].text) {\n  return [{json: {categoria: 'Other', prioridad: 'Low', solucion_sugerida: 'Error', tiempo_estimado_horas: 0, confidence: 0}}];\n}\nconst text = response.content[0].text;\nconst jsonMatch = text.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) {\n  return [{json: {categoria: 'Other', prioridad: 'Low', solucion_sugerida: text, tiempo_estimado_horas: 0, confidence: 0}}];\n}\ntry {\n  const parsed = JSON.parse(jsonMatch[0]);\n  let categoria = parsed.categoria || 'Other';\n  let prioridad = parsed.prioridad || 'Low';\n  const categoriaMap = {\n    'database': 'Database', 'base de datos': 'Database', 'db': 'Database', 'oracle': 'Database', 'sql': 'Database',\n    'network': 'Network', 'red': 'Network', 'conectividad': 'Network',\n    'security': 'Security', 'seguridad': 'Security', 'acceso': 'Security',\n    'performance': 'Performance', 'rendimiento': 'Performance', 'lentitud': 'Performance'\n  };\n  const categoriaLower = categoria.toLowerCase();\n  for (const [key, value] of Object.entries(categoriaMap)) {\n    if (categoriaLower.includes(key)) {\n      categoria = value;\n      break;\n    }\n  }\n  if (!['Database', 'Network', 'Security', 'Performance', 'Other'].includes(categoria)) {\n    categoria = 'Other';\n  }\n  const prioridadMap = {\n    'critical': 'Critical', 'critica': 'Critical', 'urgente': 'Critical',\n    'high': 'High', 'alta': 'High',\n    'medium': 'Medium', 'media': 'Medium',\n    'low': 'Low', 'baja': 'Low'\n  };\n  const prioridadLower = prioridad.toLowerCase();\n  for (const [key, value] of Object.entries(prioridadMap)) {\n    if (prioridadLower.includes(key)) {\n      prioridad = value;\n      break;\n    }\n  }\n  if (!['Critical', 'High', 'Medium', 'Low'].includes(prioridad)) {\n    prioridad = 'Low';\n  }\n  return [{json: {categoria: categoria, prioridad: prioridad, solucion_sugerida: parsed.solucion_sugerida || '', tiempo_estimado_horas: parsed.tiempo_estimado_horas || 0, confidence: parsed.confidence || 0}}];\n} catch (e) {\n  return [{json: {categoria: 'Other', prioridad: 'Low', solucion_sugerida: 'Parse error', tiempo_estimado_horas: 0, confidence: 0}}];\n}"
      },
